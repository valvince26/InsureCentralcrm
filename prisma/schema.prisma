generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// -----------------------------------------------------------------------------
// CORE TENANT & AUTH MODELS
// -----------------------------------------------------------------------------

model Organization {
  id        String   @id @default(uuid())
  name      String
  clerkId   String?  @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users           User[]
  teams           Team[]
  contacts        Contact[]
  roles           Role[]
  campaigns       Campaign[]
  pipelines       Pipeline[]
  queueItems      QueueItem[]
  queueRules      QueueRule[]
  callLogs        CallLog[]
  notes           Note[]
  tasks           Task[]
  tags            Tag[]
  customFields    CustomField[]
  imports         CSVImport[]
  settings        Setting[]
  integrations    Integration[]
  phoneNumbers    PhoneNumber[]
  auditLogs       AuditLog[]
  webhooks        Webhook[]
  notifications   Notification[]
  leadAssignments LeadAssignment[]
  opportunities   Opportunity[]
  conversations   Conversation[]
  messages        Message[]
}

enum UserRole {
  SUPER_ADMIN
  MANAGER
  AGENT
}

model User {
  id             String   @id @default(uuid())
  clerkId        String   @unique
  email          String   @unique
  firstName      String?
  lastName       String?
  role           UserRole @default(AGENT)
  isActive       Boolean  @default(true)
  dailyLeadLimit Int?

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  teamId String?
  team   Team?   @relation(fields: [teamId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  assignedContacts Contact[]        @relation("AssignedContacts")
  leadAssignments  LeadAssignment[]
  callLogs         CallLog[]
  notes            Note[]
  tasks            Task[]           @relation("AssignedTasks")
  createdTasks     Task[]           @relation("CreatedTasks")
  notifications    Notification[]
  auditLogs        AuditLog[]
  conversations    Conversation[]
}

model Team {
  id   String @id @default(uuid())
  name String

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  users     User[]
  contacts  Contact[]
  campaigns Campaign[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Role {
  id          String       @id @default(uuid())
  name        String
  permissions Permission[]

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model Permission {
  id    String @id @default(uuid())
  name  String
  roles Role[]
}

// -----------------------------------------------------------------------------
// CRM MODELS
// -----------------------------------------------------------------------------

model Contact {
  id        String  @id @default(uuid())
  firstName String
  lastName  String?
  email     String?
  phone     String?

  address String?
  city    String?
  state   String?
  zip     String?

  source      String?
  status      String? @default("New")
  disposition String?

  isDeleted Boolean @default(false)

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  assignedUserId String?
  assignedUser   User?   @relation("AssignedContacts", fields: [assignedUserId], references: [id], onDelete: SetNull)

  assignedTeamId String?
  assignedTeam   Team?   @relation(fields: [assignedTeamId], references: [id], onDelete: SetNull)

  campaignId String?
  campaign   Campaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)

  tags          Tag[]
  notes         Note[]
  tasks         Task[]
  callLogs      CallLog[]
  opportunities Opportunity[]
  queueItems    QueueItem[]

  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  conversations Conversation[]

  @@index([organizationId, isDeleted])
  @@index([assignedUserId])
  @@index([phone])
  @@index([email])
}

model Tag {
  id       String  @id @default(uuid())
  name     String
  color    String?
  category String?

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  contacts Contact[]
}

model CustomField {
  id         String @id @default(uuid())
  name       String
  type       String // text, number, date, dropdown, checkbox, phone, email
  entityType String // contact, campaign, opportunity

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

// -----------------------------------------------------------------------------
// SALES & PIPELINE
// -----------------------------------------------------------------------------

model Pipeline {
  id   String @id @default(uuid())
  name String

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  stages    PipelineStage[]
  campaigns Campaign[]
}

model PipelineStage {
  id    String @id @default(uuid())
  name  String
  order Int

  pipelineId String
  pipeline   Pipeline @relation(fields: [pipelineId], references: [id], onDelete: Cascade)

  opportunities Opportunity[]
}

model Opportunity {
  id     String @id @default(uuid())
  title  String
  value  Float?
  status String @default("Open") // Open, Won, Lost

  contactId String
  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  stageId String
  stage   PipelineStage @relation(fields: [stageId], references: [id], onDelete: Restrict)

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// -----------------------------------------------------------------------------
// CAMPAIGNS & DIALER
// -----------------------------------------------------------------------------

model Campaign {
  id             String  @id @default(uuid())
  name           String
  description    String?
  status         String  @default("Active") // Active, Paused, Completed
  priority       Int     @default(1)
  dailyCap       Int?
  callerId       String?
  script         String?
  transferNumber String?

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  teamId String?
  team   Team?   @relation(fields: [teamId], references: [id], onDelete: SetNull)

  pipelineId String?
  pipeline   Pipeline? @relation(fields: [pipelineId], references: [id], onDelete: SetNull)

  contacts   Contact[]
  queueItems QueueItem[]
}

model QueueRule {
  id                String  @id @default(uuid())
  name              String
  priority          Int
  maxAttempts       Int     @default(3)
  retryIntervalMins Int     @default(60)
  followUpDelayMins Int?
  skipCooldown      Boolean @default(false)

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model QueueItem {
  id            String    @id @default(uuid())
  status        String    @default("Pending") // Pending, In Progress, Completed, Requeued, Skipped, DNC, Invalid
  priority      Int       @default(0)
  attempts      Int       @default(0)
  nextAttemptAt DateTime?

  contactId String
  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  campaignId String?
  campaign   Campaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, nextAttemptAt, priority])
}

model LeadAssignment {
  id         String   @id @default(uuid())
  assignedAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

// -----------------------------------------------------------------------------
// CALLS, NOTES, & TASKS
// -----------------------------------------------------------------------------

model CallLog {
  id           String  @id @default(uuid())
  durationSecs Int?
  disposition  String?

  contactId String
  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  recording CallRecording?

  createdAt DateTime @default(now())
}

model CallRecording {
  id  String @id @default(uuid())
  url String

  callLogId String  @unique
  callLog   CallLog @relation(fields: [callLogId], references: [id], onDelete: Cascade)
}

model Note {
  id      String @id @default(uuid())
  content String

  contactId String
  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

model Task {
  id          String    @id @default(uuid())
  title       String
  description String?
  dueDate     DateTime?
  status      String    @default("Pending") // Pending, Completed

  contactId String?
  contact   Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)

  assignedToId String
  assignedTo   User   @relation("AssignedTasks", fields: [assignedToId], references: [id], onDelete: Cascade)

  createdById String
  createdBy   User   @relation("CreatedTasks", fields: [createdById], references: [id], onDelete: Cascade)

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// -----------------------------------------------------------------------------
// IMPORTS & SYSTEM
// -----------------------------------------------------------------------------

model CSVImport {
  id          String @id @default(uuid())
  filename    String
  status      String @default("Processing") // Pending, Processing, Completed, Failed
  totalRows   Int    @default(0)
  successRows Int    @default(0)
  errorRows   Int    @default(0)

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  rows CSVImportRow[]

  createdAt DateTime @default(now())
}

model CSVImportRow {
  id           String  @id @default(uuid())
  rawData      String
  status       String  @default("Pending") // Pending, Success, Error
  errorMessage String?

  importId  String
  importRef CSVImport @relation(fields: [importId], references: [id], onDelete: Cascade)
}

model Setting {
  id    String @id @default(uuid())
  key   String
  value String

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, key])
}

model Integration {
  id       String  @id @default(uuid())
  provider String // Twilio, LeadConnector, RingCentral
  apiKey   String?
  config   String? // JSON blob

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model PhoneNumber {
  id       String @id @default(uuid())
  number   String
  provider String

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id         String  @id @default(uuid())
  action     String
  entityType String
  entityId   String
  details    String? // JSON blob

  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

model Webhook {
  id       String   @id @default(uuid())
  url      String
  events   String[] // E.g. ['contact.created', 'call.completed']
  isActive Boolean  @default(true)

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model Notification {
  id      String  @id @default(uuid())
  message String
  isRead  Boolean @default(false)
  type    String

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

// -----------------------------------------------------------------------------
// MESSAGING HUB
// -----------------------------------------------------------------------------

model Conversation {
  id     String @id @default(uuid())
  status String @default("Active") // Active, Archived, Spam

  contactId String
  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  messages Message[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  lastMessageAt DateTime @default(now())
}

model Message {
  id        String @id @default(uuid())
  body      String
  direction String // Inbound, Outbound
  status    String @default("Sent") // Sent, Delivered, Failed, Read

  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

// -----------------------------------------------------------------------------
// EMAIL INBOX
// -----------------------------------------------------------------------------

model EmailThread {
  id             String       @id @default(uuid())
  subject        String
  status         String       @default("Inbox") // Inbox, Sent, Archived, Trash

  contactId      String
  contact        Contact      @relation(fields: [contactId], references: [id], onDelete: Cascade)

  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  emails         EmailMessage[]

  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  lastActivityAt DateTime     @default(now())
}

model EmailMessage {
  id             String       @id @default(uuid())
  from           String
  to             String
  body           String
  direction      String       // Inbound, Outbound

  threadId       String
  thread         EmailThread  @relation(fields: [threadId], references: [id], onDelete: Cascade)

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt      DateTime     @default(now())
}
